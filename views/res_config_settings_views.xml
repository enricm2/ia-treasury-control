<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="res_config_settings_view_form_iatc" model="ir.ui.view">
        <field name="name">res.config.settings.view.form.iatc</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="base_setup.res_config_settings_view_form"/>
        <field name="priority">100</field>
        <field name="arch" type="xml">
            <xpath expr="//form" position="inside">
                <app string="IA Treasury Control" name="ia_agents_treasury_control" groups="base.group_system">

                    <!-- License -->
                    <block title="SaaS License">
                        <setting string="License key">
                            <field name="iatc_license_key" password="True"/>
                            <div class="text-muted">
                                Format: XXXX-XXXX-XXXX-XXXX · Get your license at
                                <a href="https://apps.uniasser.net" target="_blank">apps.uniasser.net</a>
                            </div>
                        </setting>
                        <setting string="License status">
                            <field name="iatc_license_status" readonly="1"/>
                            <field name="iatc_license_customer" readonly="1"
                                   attrs="{'invisible': [('iatc_license_customer', '=', '')]}"/>
                            <field name="iatc_license_expires" readonly="1"
                                   attrs="{'invisible': [('iatc_license_expires', '=', '')]}"/>
                            <button name="action_validate_license" type="object"
                                    string="Validate license" class="btn-secondary mt8"/>
                        </setting>
                    </block>

                    <!-- Odoo connection for remote agents -->
                    <block title="Odoo Connection (for remote agents)">
                        <setting string="Odoo API Key"
                                 help="API key so the Uniasser server can read/write your Odoo.">
                            <field name="iatc_odoo_api_key" password="True"/>
                            <button name="action_generate_odoo_api_key" type="object"
                                    string="Generate API Key automatically" class="btn-primary mt8"/>
                            <div class="text-muted mt4">
                                Click the button to generate and save the key automatically,
                                or create one manually at Settings → Users → your user → API Keys.
                            </div>
                        </setting>
                        <setting string="Odoo user (login)"
                                 help="Login of the user whose API Key was generated. Filled automatically when using the button above.">
                            <field name="iatc_odoo_login"/>
                        </setting>
                    </block>

                    <!-- MCP Server -->
                    <block title="MCP Server">
                        <setting string="MCP Token (OAuth Client Secret)"
                                 help="Paste this value in 'OAuth Client Secret' when adding the MCP server in claude.ai or Gemini CLI.">
                            <field name="iatc_mcp_secret_token" password="True"/>
                            <button name="action_generate_mcp_token" type="object"
                                    string="Regenerate token" class="btn-secondary mt8"/>
                        </setting>
                        <setting string="MCP Server URL">
                            <field name="iatc_mcp_endpoint_url" readonly="1"/>
                            <div class="text-muted">
                                Use this URL when configuring the MCP server in your AI client.
                            </div>
                        </setting>
                        <setting string="OAuth Client ID">
                            <field name="iatc_mcp_oauth_client_id" readonly="1"/>
                        </setting>
                    </block>

                    <!-- AI Provider -->
                    <block title="Artificial Intelligence">
                        <setting string="Active AI provider"
                                 help="Choose which AI provider generates reports and processes invoices. Fill the corresponding API key below.">
                            <field name="iatc_llm_provider"/>
                        </setting>

                        <!-- Claude -->
                        <setting string="Anthropic API Key (Claude)"
                                 help="Get it at console.anthropic.com. Required if provider is Claude.">
                            <field name="iatc_anthropic_api_key" password="True"/>
                        </setting>
                        <setting string="Claude model"
                                 attrs="{'invisible': [('iatc_llm_provider', '!=', 'claude')]}">
                            <field name="iatc_claude_model"/>
                        </setting>

                        <!-- Gemini -->
                        <setting string="Gemini API Key (Google)"
                                 help="Get it at aistudio.google.com. Free tier available. Required if provider is Gemini.">
                            <field name="iatc_gemini_api_key" password="True"/>
                        </setting>
                        <setting string="Gemini model"
                                 attrs="{'invisible': [('iatc_llm_provider', '!=', 'gemini')]}">
                            <field name="iatc_gemini_model"/>
                        </setting>

                        <!-- OpenAI -->
                        <setting string="OpenAI API Key (ChatGPT)"
                                 help="Get it at platform.openai.com. Required if provider is ChatGPT.">
                            <field name="iatc_openai_api_key" password="True"/>
                        </setting>
                        <setting string="OpenAI model"
                                 attrs="{'invisible': [('iatc_llm_provider', '!=', 'openai')]}">
                            <field name="iatc_openai_model"/>
                        </setting>

                        <!-- Grok -->
                        <setting string="Grok API Key (xAI)"
                                 help="Get it at console.x.ai. Required if provider is Grok.">
                            <field name="iatc_grok_api_key" password="True"/>
                        </setting>
                        <setting string="Grok model"
                                 attrs="{'invisible': [('iatc_llm_provider', '!=', 'grok')]}">
                            <field name="iatc_grok_model"/>
                        </setting>
                    </block>

                </app>
            </xpath>
        </field>
    </record>
</odoo>
